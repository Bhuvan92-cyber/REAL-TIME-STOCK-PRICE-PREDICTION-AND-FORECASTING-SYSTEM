{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "framework": "streamlit",
  "env": {
    "PYTHONPATH": "./",
    "STREAMLIT_SERVER_HEADLESS": "true",
    "STREAMLIT_SERVER_PORT": "8501",
    "STREAMLIT_SERVER_ENABLECORS": "false"
  },
  "functions": {
    "api/app.py": {
      "runtime": "python3.10"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
